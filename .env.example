# =========================================================================
# CONFIGURAÇÕES DO uRag-go (Exemplo)
# =========================================================================
# Copie este arquivo para .env e descomente a opção desejada.
# =========================================================================

URAG_TRANSPORT=http
URAG_HTTP_ADDR=:8080
URAG_DB=./urag_mcp.db
URAG_SQL_DSN=urag_sql.db

# HTTP_PROXY=http://127.0.0.1:8080
# HTTPS_PROXY=http://127.0.0.1:8080
# NO_PROXY=localhost,127.0.0.1

# OPÇÃO A: OLLAMA LOCAL (Configuração Padrão)
URAG_LLM_PROVIDER=ollama
URAG_LLM_MODEL=granite4:micro-h
URAG_EMBEDDING_PROVIDER=ollama
URAG_EMBEDDING_MODEL=nomic-embed-text

# OPÇÃO B: OPENAI OU PROVEDORES DE NUVEM COMPATÍVEIS
# URAG_LLM_PROVIDER=openai
# URAG_LLM_MODEL=gpt-4o-mini
# URAG_LLM_API_KEY=sk-proj-SUA-CHAVE-AQUI
# URAG_LLM_BASE_URL=https://api.openai.com/v1

# URAG_EMBEDDING_PROVIDER=openai
# URAG_EMBEDDING_MODEL=text-embedding-3-small
# URAG_EMBEDDING_API_KEY=sk-proj-SUA-CHAVE-AQUI
# URAG_EMBEDDING_BASE_URL=https://api.openai.com/v1
